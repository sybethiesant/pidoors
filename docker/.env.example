# PiDoors Docker — required secrets template
#
# Copy this file to ".env" in the directory where you run `docker compose`
# (next to docker-compose.yml, or the compose working directory) and fill in
# REAL values. NEVER commit the real ".env" — only this ".example".
#
# There are intentionally NO defaults baked into the images or entrypoints:
# if any of these is unset the containers FAIL CLOSED (exit non-zero) rather
# than booting with a guessable credential. This is access-control software.
#
# Generate strong values, e.g.:
#   DB_PASS=$(openssl rand -base64 24)
#   DB_ROOT_PASS=$(openssl rand -base64 24)
#   ADMIN_PASS=$(openssl rand -base64 18)

# Password for the 'pidoors' MariaDB user (must match on server and door).
DB_PASS=

# MariaDB root password (server only).
DB_ROOT_PASS=

# Initial web-UI admin login.
ADMIN_EMAIL=
ADMIN_PASS=
