# PiDoors - Files to ignore

# Configuration files with sensitive data
pidoorserv/includes/config.php
pidoors/conf/config.json
pidoors/conf/zone.json
*.remote

# Runtime files
pidoors/cache/
pidoors/__pycache__/
__pycache__/
*.pyc
*.pyo
*.log

# Backup / temp files
*.bak
*.swp
*~

# Release tarballs
*.tar.gz

# OS files
.DS_Store
Thumbs.db

# Test / coverage artifacts
.coverage
.coveragerc
htmlcov/
.pytest_cache/
pytest.ini
requirements-test.txt
tests/

# React SPA build artifacts
pidoors-ui/node_modules/
pidoors-ui/dist/
pidoors-ui/.tsbuildinfo

# IDE / tools
.vscode/
.idea/
*.sublime-*
.claude/
